{
  "buildCommand": "npm run build -w packages/shared && npm run build -w packages/viewer",
  "outputDirectory": "packages/viewer/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "http://localhost:3001/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "http://localhost:3001/socket.io/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
