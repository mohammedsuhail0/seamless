{
  "buildCommand": "npm run build -w packages/shared && npm run build -w packages/viewer",
  "outputDirectory": "packages/viewer/dist",
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://browsync-api.onrender.com/api/$1"
    },
    {
      "source": "/socket.io/(.*)",
      "destination": "https://browsync-api.onrender.com/socket.io/$1"
    },
    {
      "source": "/room/:path*",
      "destination": "/"
    },
    {
      "source": "/(.*)",
      "destination": "/"
    }
  ]
}
